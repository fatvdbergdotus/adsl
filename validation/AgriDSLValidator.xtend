	// each requirement should have a minimum and/or maximum
	def eitherMinimumOrMaximumRequirement (List<Requirement> rs){
		var boolean foundError=false
		for(r:rs){
			if(r.minReq.isEmpty && r.maxReq.isEmpty){
				error("A requirement should at least either have a minimum or maximum OperationSpace",null)
				foundError=true	
			}
		}
		return foundError 
	}

	// Designspace dimension values should be unique
	def dSpaceDimNamesUnique (DesignSpace ds){
		var boolean foundError=false
		for(dim:ds.DSpaceDimension){
			if(!uniqueValues(dim.value)){
				error("DesignSpaceDimension \""+dim.dsDimensionName+"\" has duplicate value(s)",null)
				foundError=true	
			}
		}
		return foundError
	}
	
	// Designspace dimension names should be unique
	def dSpaceDimValuesUnique (DesignSpace ds){
		var boolean foundError=false
		var dim_names=dSDimToString(ds.DSpaceDimension)
		if(!uniqueValues(dim_names)){
			error("DesignSpaceDimension names are not unique",null)
			foundError=true	
		}
		return foundError
	}	
	


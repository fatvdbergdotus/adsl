	def displayRequirementsPassed(Model m, List<Pair<String, Pair<String, String>>> DSISyspartReq){
		var mainSystem = m.eAllContents.toIterable.filter(typeof(aSystem)).toList.head
		var reqs       = m.eAllContents.toIterable.filter(typeof(Requirement)).toList
		
		for(r:reqs){
			var Set<String> validDSIs = new HashSet
			for(dsr:DSISyspartReq)
				if(dsr.value.key==mainSystem.name)
					if(dsr.value.value.contains(r.name))
						validDSIs.add(convertDSItoBracketNotation(dsr.key))
			info("Designs meeting requirement: "+listToString(validDSIs.toList),r,null)
		}
		return false // no errors found
	}
	
	// displays for each system and part, which requirements are passed for each design.
	def displayDSISyspartReq(Model m, List<Pair<String, Pair<String, String>>> DSISyspartReq){
		var reqs 			= m.eAllContents.toIterable.filter(typeof(Requirement)).toList
		
		var Set<String> sysparts = new HashSet  // fetch unique sysparts
		for(dsisyspartreq:DSISyspartReq)
			sysparts.add(dsisyspartreq.value.key)
		
		for(s:sysparts){
			for(r:reqs){
				var Set<String> validDSIs = new HashSet
				for(dsr:DSISyspartReq(m))
					if(dsr.value.key==s)
						if(dsr.value.value.contains(r.name)) //TO DO: make this check a bit more thorough
							validDSIs.add(convertDSItoBracketNotation(dsr.key))
				deliverInfoToModelComponent(s,"Req "+r.name+": "+listSubSetToString(validDSIs.toList,10),m)	
			}
			
		}
		return false // no errors found
	}
	
	def String convertDSItoBracketNotation (String dsi){
		var d=dsi
		d=d.substring(1,d.length)
		d="("+d
		d=d.substring(0,d.length-1)
		d=d+")"	
		d.replace("_",",")	
		return d
	}
	
	// returns for each DSI and System+part, which requirements are met
	def List<Pair<String, Pair<String, String>>> DSISyspartReq (Model m) {
		var reqs 		 = m.eAllContents.toIterable.filter(typeof(Requirement)).toList
		var dspace 		 = m.eAllContents.toIterable.filter(typeof(DesignSpace)).head
		var dsm 		 = AgriDSLGenerator.designSpaceDimensionNames(dspace)
		var otherSystems = m.eAllContents.toIterable.filter(typeof(aSystem)).toList.tail.toList
		var parts 		 = m.eAllContents.toIterable.filter(typeof(Part)).toList
		
		var List<Pair<String, Pair<String, String>>> SyspartReq = new ArrayList
		for(dsi:CreateLangConstructs.returnDesignInstances(dspace)){
			var colorGraphString = AgriDSLGeneratorToGraphvizCloneForValidation.trav(reqs, m, dsm, dsi,  otherSystems,  parts,  0, true, true)
			var DSISyspartReq    = AgriDSLGeneratorToGraphvizCloneForValidation.returnDSISyspartReq
			SyspartReq.addAll(DSISyspartReq)
		}
		return SyspartReq
	}
	
	// checks whether no system or part references to references exist
	def noSystemOrPartreferencesToReferences(Model m){
		var boolean errorsFound=false
		var pIDs = m.eAllContents.toIterable.filter(typeof(PartID))
		var sIDs = m.eAllContents.toIterable.filter(typeof(SystemID))
		
		for(p1:pIDs)
			for(p2:pIDs)
				if(p1.partID==p2.name){
					error("Referencing to a reference is not allowed: "+p1,p1,null)
					errorsFound=true
				}
		
		for(s1:sIDs)
			for(s2:sIDs)
				if(s1.systemID==s2.name){
					error("Referencing to a reference is not allowed: "+s1,s1,null)
					errorsFound=true	
				}
		
		return errorsFound
	}
	
	// names of systems, systemsIDs, parts, partIDs and desAlternatives must be unique
	def boolean uniqueNamesForSystemsPartsDesalts(Model m){
		var errorsFound=false
		var List<SystemOrPart> allSystemAndParts = allModelComponents(m)
		for(c1:allSystemAndParts)
			for(c2:allSystemAndParts)
				if(CycleDetection.sysorpartName(c1)==CycleDetection.sysorpartName(c2) && c1!=c2){
					error("Duplicate name found: "+CycleDetection.sysorpartName(c1),c2,null)
					errorsFound=true	
				}
		return errorsFound
	}

	// each abstract system and part should refer to an existing implemented system
	def boolean validSystemandPartIDs (Model m){
		var errorsFound=false
		var List<String> systems =   m.eAllContents.toIterable.filter(typeof(aSystem)).map[system | system.name ].toList
		var List<String> parts = 	 m.eAllContents.toIterable.filter(typeof(Part)).map[part | part.name ].toList
		var pIDs = 	    			 m.eAllContents.toIterable.filter(typeof(PartID))
		var sIDs = 					 m.eAllContents.toIterable.filter(typeof(SystemID))		
		
		for(p:pIDs)
			if(!parts.contains(p.partID)){
				error("Illegal reference to a part: "+p.partID,p,null)
				errorsFound=true
			}

		for(s:sIDs)
			if(!systems.contains(s.systemID)){
				error("Illegal reference to a system: "+s.systemID,s,null)
				errorsFound=true
			}
		return errorsFound		
	}
	
	// check whether the model is free of cycles that can be the result of SystemID and PartID references.
	def cycles (Model m){
		var errorsFound=false
		Stopwatch.init
		Stopwatch.start("inputValidation","cycles")
		for(c:CycleDetection.returnCyclePaths(m)){
			deliverErrorToModelComponent(c.head,"Detected a cycle: "+listOfStringToString(c),m)
			errorsFound=true	
		}
		Stopwatch.stop
		//System.out.println(Stopwatch.entriesToString)
		return errorsFound
	}
	
	def deliverErrorToModelComponent (String component, String message, Model m){
		var List<SystemOrPart> allSystemAndParts = allModelComponents(m)
		for(c:allSystemAndParts)
			if(component==CycleDetection.sysorpartName(c))
				error(message,c,null)
	}
	
	def deliverWarningToModelComponent (String component, String message, Model m){
		var List<SystemOrPart> allSystemAndParts = allModelComponents(m)
		for(c:allSystemAndParts)
			if(component==CycleDetection.sysorpartName(c))
				warning(message,c,null)
	}
	
	def deliverInfoToModelComponent (String component, String message, Model m){
		var List<SystemOrPart> allSystemAndParts = allModelComponents(m)
		for(c:allSystemAndParts)
			if(component==CycleDetection.sysorpartName(c))
				info(message,c,null)
	}
	
	def List<SystemOrPart> allModelComponents (Model m){
		var systems =   m.eAllContents.toIterable.filter(typeof(aSystem))
		var parts = 	m.eAllContents.toIterable.filter(typeof(Part))
		var pIDs = 	    m.eAllContents.toIterable.filter(typeof(PartID))
		var sIDs = 		m.eAllContents.toIterable.filter(typeof(SystemID))
		var desAlts =   m.eAllContents.toIterable.filter(typeof(DesAlternative))
		
		var List<SystemOrPart> allSystemAndParts = new ArrayList
		allSystemAndParts.addAll(systems)
		allSystemAndParts.addAll(parts)
		allSystemAndParts.addAll(pIDs)
		allSystemAndParts.addAll(sIDs)
		allSystemAndParts.addAll(desAlts)
		return allSystemAndParts		
	}
	

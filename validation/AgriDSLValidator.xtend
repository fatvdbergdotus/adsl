		var pathSensor   = backtracking.pathCPStoComponent(mainSystem, systems, parts, fl.sensorID.head, dsm, dsi)
		info("Path from CPS to sensor: "+pathSensor,fl,null)
		var pathActuator = backtracking.pathCPStoComponent(mainSystem, systems, parts, fl.actuatorID.head, dsm, dsi)
		info("Path from CPS to actuator: "+pathActuator,fl,null)
		var feedbackLoop = backtracking.generateFeedbackloop (fl, mainSystem, systems,  parts, dsm, dsi)
		info("Path from sensor to actuator: "+feedbackLoop,fl,null)		
	}


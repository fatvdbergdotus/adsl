	def List<String> dsValuesToString (List<DesValueSystemOrPartPair> das){
		var ret=new ArrayList<String>
		for(da:das)
			ret.add(da.dsValue.head)
		return ret
	}
	
	def List<String> dSDimToString (List<DesignSpaceDimension> das){
		var ret=new ArrayList<String>
		for(da:das)
			ret.add(da.dsDimensionName.head)
		return ret
	}	
	
	def boolean similarLists (List<String> l1, List<String> l2){
		return l1.equals(l2)
	}
	
	def boolean uniqueValues (List<String> vals){
		return (vals.length==vals.clone.toSet.length)
	}
	
	

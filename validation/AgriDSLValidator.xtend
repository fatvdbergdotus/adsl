	@Check
	def generatePathsForFeedbackLoopViaBacktracking(Model m){
		var mainSystem = m.eAllContents.toIterable.filter(typeof(aSystem)).toList.head
		var systems = m.eAllContents.toIterable.filter(typeof(aSystem)).toList
		var parts = m.eAllContents.toIterable.filter(typeof(Part)).toList
		var feedbackLoops = m.eAllContents.toIterable.filter(typeof(FeedbackLoop)).toList
		var dspace = m.eAllContents.toIterable.filter(typeof(DesignSpace)).head
		var dsm = AgriDSLGenerator.designSpaceDimensionNames(dspace)
		var dsis = CreateLangConstructs.returnDesignInstances(dspace)
		
		for(fl:feedbackLoops){
			checkWhetherSensorAndActuatorExist(fl,parts)
			
			for(dsi:dsis){
				// displays extra information about the feedbackloop, mainly for testing purposes. 
				//testExtraBacktrackingInFormation(mainSystem, systems, parts, dsm, dsi, fl)
				var List<String> cleanFeedbackLoop = backtracking.generateCleanFeedbackloop (fl, mainSystem, systems,  parts, dsm, dsi)
				if(cleanFeedbackLoop!=null)
					info("Clean path from sensor to actuator ( design "+List2String(dsi)+" ): "+cleanFeedbackLoop,fl,null)
			}
		}
	}
	

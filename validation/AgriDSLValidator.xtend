	def checkWhetherSensorAndActuatorExist(FeedbackLoop fl, List<Part> ps){
		var Part sensor =   lookupPart(fl.sensorID.head,ps)
		var Part actuator = lookupPart(fl.actuatorID.head,ps)
		if(sensor==null)
			warning("Sensor "+sensor.name+" not found (as a Part) in the model",fl,null)
		if(actuator==null)
			warning("Actuator "+actuator.name+" not found (as a Part) in the model",fl,null)
		if(sensor==null || isSensorOrActuator(sensor)!=1)
			warning("Sensor "+sensor.name+" is not a sensor in the model",fl,null)
		if(actuator==null || isSensorOrActuator(actuator)!=2)
			warning("Actuator "+actuator.name+" is not an actuator in the model",fl,null)
	}

	def static Part lookupPart (String pid, List<Part> ps){
		for(p:ps)
			if(p.name==pid)
				return p
		return null
	}
	
	def static int isSensorOrActuator (Part p){
		if(p.soa.empty) 
			return 0 // neither Sensor, nor Actuator	
		switch(p.soa.head){
			Sensor:   return 1
			Actuator: return 2
		}
	}
	
	@Check // make sure that the scenario consists of unique feedbackloops
	def scenarioConsistsOfUniqueFeedbackloops (Model m){
		var scenarios = m.scen.head
		var sfbl      = scenarios.sfbl
		if(sfbl.size>1)
			for(cnt1:0..sfbl.size-2)
				for(cnt2:cnt1+1..sfbl.size-1)
					if(sfbl.get(cnt1).name.equals(sfbl.get(cnt2).name))
						error("feedbackloop "+sfbl.get(cnt1).name+" occurs more then once in the scenario",m,null)
	}
	

	def static Pair<String,OperationSpace> trav (SystemOrPart s, List<String> dsm, List<String> dsi, List<aSystem> systems, List<Part> parts, int indent, boolean enclosekw,boolean evaluateOS){		
		var Pair<String,OperationSpace> ret_os

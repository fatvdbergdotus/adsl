	def static Pair<String,OperationSpace> trav (SystemID sid, List<String> dsm, List<String> dsi, List<aSystem> systems, List<Part> parts, int indent, boolean enclosekw, boolean evaluateOS){
		var Pair<String,OperationSpace> ret_os
		var ret=col(indent)+ekw("systemid",enclosekw)+"\n"
		ret=ret+graphvizPartIDSystemIDDesAltNode("SystemID",sid.name) // add node
		//ret=ret+"\n"+sid.name+":"+sid.name+"0 -> "+sid.systemID+":"+sid.systemID+"999\n" // add connection
		GLOBALgraphConnections.put(sid.name+":"+sid.name+"0",sid.systemID+":"+sid.systemID+"999")
		for(s:systems) // find the right system
			if(s.name==sid.systemID){
				ret=ret+col(indent+1)+sid.name+"\n"
				ret_os=trav (s,dsm,dsi,systems,parts,indent+2,enclosekw,evaluateOS)
				return new Pair(ret+ret_os.key,ret_os.value)
			}
		throw new Throwable("Illegal reference: System with "+sid+" not found.")
	}
	
	def static Pair<String,OperationSpace> trav (PartID pid, List<String> dsm, List<String> dsi, List<aSystem> systems, List<Part> parts, int indent, boolean enclosekw, boolean evaluateOS){
		var Pair<String,OperationSpace> ret_os
		var ret=col(indent)+ekw("partid",enclosekw)+"\n"
		ret=ret+graphvizPartIDSystemIDDesAltNode("PartID",pid.name) // add node
		//ret=ret+"\n"+pid.name+":"+pid.name+"0 -> "+pid.partID+":"+pid.partID+"999\n" // add connection
		GLOBALgraphConnections.put(pid.name+":"+pid.name+"0",pid.partID+":"+pid.partID+"999")
		for (p:parts){ // find the right part
			if(p.name==pid.partID){
				ret=ret+col(indent+1)+pid.name+"\n"
				ret_os=trav (p,dsm,dsi,systems,parts,indent+2,enclosekw,evaluateOS)
				return new Pair(ret+ret_os.key,ret_os.value)
			}
		}
		throw new Throwable("Illegal reference: Part with "+pid+" not found.")
	}

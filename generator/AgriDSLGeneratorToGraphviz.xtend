	def static systemOrPartsName (SystemOrPart s){
		switch(s){
			aSystem: 		return s.name
			SystemID:		return s.name
			Part: 			return s.name
			PartID:  		return s.name
			DesAlternative: return s.dsDimensionName.head
			default: 		throw new Throwable("SystemOrPart: invalid type")
		}
	}
	
	def static Pair<String,OperationSpace> trav (aSystem s, List<String> dsm, List<String> dsi, List<aSystem> systems, List<Part> parts, int indent, boolean enclosekw, boolean evaluateOS){
		var String ret_later = ""
		var List<OperationSpace> oss = new ArrayList
		var ret=col(indent)+ekw("system",enclosekw)+"\n"
		//ret=ret+col(indent+1)+graphvizNode(s.name,s.systemOrParts.length)+"\n"
		
		ret=ret+col(indent+1)+ekw("ospace",enclosekw)+"\n"
		
		if(s.OSpace.isEmpty)
			oss.add(LangConstructPopulations.emptyOS)
		else
			oss.add(s.OSpace.head)
		
		var cnt=0
		for(sop:s.systemOrParts){
			var retos=trav(sop,dsm,dsi,systems,parts,indent+2,enclosekw,evaluateOS)
			ret_later=ret_later+retos.key
			oss.add(retos.value)
			//ret=ret+"\n"+s.name+":"+s.name+cnt+" -> "+systemOrPartsName(sop)+":"+systemOrPartsName(sop)+"999\n"
			GLOBALgraphConnections.put(s.name+":"+s.name+cnt,systemOrPartsName(sop)+":"+systemOrPartsName(sop)+"999")
			cnt=cnt+1
		}			
		
		// depending on whether the operation space is evaluated, either the original operation space or the merged one is used.
		var OperationSpace ossMerge
		if(evaluateOS)
			ossMerge=CreateLangConstructs.mergeOMS(oss)
		else
			ossMerge=oss.head

		ret=ret+col(indent+1)+graphvizSystemPartNode(s.name,s.systemOrParts.length,ossMerge,evaluateOS)+"\n" // moved from above (see commented line)
		var ret_os=trav(ossMerge,dsm,dsi,systems,parts,indent+2,enclosekw,evaluateOS)

		ret=ret+ret_later

		addDSISyspartReq(dsi,s.name,operationSpaceMeetsRequirements(ret_os.value).toString)
		addDSISyspartOS(dsi,s.name,ret_os.value)
		return new Pair(ret,ret_os.value)
	}
	
	def static Pair<String,OperationSpace> trav (DesAlternative desalt, List<String> dsm, List<String> dsi, List<aSystem> systems, List<Part> parts, int indent, boolean enclosekw, boolean evaluateOS){
		var Pair<String,OperationSpace> ret_os
		var ret=col(indent)+ekw("desalternative",enclosekw)+"\n"
		ret=ret+graphvizPartIDSystemIDDesAltNode("DesAlt",desalt.dsDimensionName.head) // add node
		ret=ret+col(indent+1)+desalt.dsDimensionName.head+"\n"
		for(cnt:0..dsm.length-1){
			if(desalt.dsDimensionName.head==dsm.get(cnt)){ // the right dimension 
				var value=dsi.get(cnt) // the belonging value
				for(dval:desalt.ds)
					if(value==dval.dsValue.head){ // the right value
						//ret=ret+"\n"+desalt.dsDimensionName.head+":"+desalt.dsDimensionName.head+"0 -> "+dval.dsValue.head+":"+dval.dsValue.head+"999\n" // add connection
						GLOBALgraphConnections.put(desalt.dsDimensionName.head+":"+desalt.dsDimensionName.head+"0",dval.dsValue.head+":"+dval.dsValue.head+"999")
				
						ret_os=trav(dval, dsm, dsi, systems, parts, indent+2,enclosekw,evaluateOS)
						return new Pair(ret+ret_os.key,ret_os.value)
					}
				}
		}
		throw new Throwable("DesAlternative: dimension with name \""+desalt.dsDimensionName+"\" not found.")
	}
	
	def static Pair<String,OperationSpace> trav (DesValueSystemOrPartPair desalts, List<String> dsm, List<String> dsi, List<aSystem> systems, List<Part> parts, int indent, boolean enclosekw, boolean evaluateOS){
		var Pair<String,OperationSpace> ret_os
		var ret=col(indent)+ekw("desalternatives",enclosekw)+"\n"
		ret=ret+col(indent+1)+desalts.dsValue.head+"\n" 
		ret_os=trav(desalts.systemOrParts.head,dsm,dsi,systems,parts,indent+2,enclosekw,evaluateOS)
		
		ret=ret+graphvizDesAltValueNode("DesAltValue",desalts.dsValue.head)
		GLOBALgraphConnections.put(desalts.dsValue.head+":"+desalts.dsValue.head+"0",systemOrPartsName(desalts.systemOrParts.head)+":"+systemOrPartsName(desalts.systemOrParts.head)+"999")
		
		return new Pair(ret+ret_os.key,ret_os.value)
	}
	
	def static Pair<String,OperationSpace> trav (Part p, List<String> dsm, List<String> dsi, List<aSystem> systems, List<Part> parts, int indent, boolean enclosekw, boolean evaluateOS){
		var Pair<String,OperationSpace> ret_os
		var ret=col(indent)+ekw("part",enclosekw)+"\n"

		if(p.OSpace.isEmpty)
			p.OSpace.add(LangConstructPopulations.emptyOS)

		ret=ret+col(indent+1)+graphvizSystemPartNode(p.name,0,p.OSpace.head,evaluateOS)+"\n"
		
		for(os:p.OSpace){
			ret=ret+col(indent+1)+ekw("ospace",enclosekw)+"\n"
			ret_os=trav(os,dsm,dsi,systems,parts,indent+2,enclosekw,evaluateOS)
		}
		//return new Pair(ret+ret_os.key,ret_os.value)
		addDSISyspartReq(dsi,p.name,operationSpaceMeetsRequirements(ret_os.value).toString)
		addDSISyspartOS(dsi,p.name,ret_os.value)
		return new Pair(ret,ret_os.value)
	}
	
	def static Pair<String,OperationSpace> trav (OperationSpace os, List<String> dsm, List<String> dsi, List<aSystem> systems, List<Part> parts, int indent, boolean enclosekw, boolean evaluateOS){
		var ret=col(indent)+ekw("operationspace",enclosekw)+"\n"
		for(od:os.opModeDimension){
			ret=ret+trav(od,dsm,dsi,systems,parts,indent+1,enclosekw, evaluateOS)
		}
		return new Pair(ret,os)
	}
	

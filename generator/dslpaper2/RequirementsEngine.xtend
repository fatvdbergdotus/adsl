	// check whether experiment 2 is similar to all experiments and thus redundant. TRUE: redundant
	def static boolean experimentIsRedundantAll(MeasurementRequirementElicitation m, ExperimentSpace es, List<String> exp){
		// four counters to keep track of redundanct signs
		var gt=0
		var im=0
		var ni=0
		var nr=0
		var all=0
		var cnt=0
		var variable = ResolveAExp.retrieveExperimentSpaceElemens(es)
		var variableFiltered = new ArrayList<List<String>>
		for(v:variable)
			 if(!zerosInTheExpermimentParameters(m,es,v)) // comparisons to experiments with zeros are skipped
			 	variableFiltered.add(v)
		
		for(v:variableFiltered){
		    var redundant = experimentIsRedundant(m,es,v,exp)
			if(redundant.get(0)) gt=gt+1
			if(redundant.get(1)) im=im+1
			if(redundant.get(2)) ni=ni+1
			if(redundant.get(3)) nr=nr+1
			if(redundant.get(0) && redundant.get(1) && redundant.get(2) && redundant.get(3)) all=all+1
			cnt=cnt+1
		}
		return all>0
	}
	
	// check whether experiment 2 is similar to experiment 1 and thus redundant; the parameters of experiment 2 are multipliers of experiment 1
	def static List<Boolean> experimentIsRedundant(MeasurementRequirementElicitation m, ExperimentSpace es, List<String> expVariable, List<String> exp){
		var gt = greaterThan(m,es,exp,expVariable) 						// an experiment has to be greater than the variable to be redundant
		var im = isMultiplication(m,es,exp,expVariable)   				// an experiment hat to be a constant multiplier to be redundant
	    var ni = ResolveAExp.resolveAExp(m.iterations,es,expVariable) == ResolveAExp.resolveAExp(m.iterations,es,exp)		// same number of iterations
		var	nr = ResolveAExp.resolveAExp(m.runs,es,expVariable) == ResolveAExp.resolveAExp(m.runs,es,exp)					// same number of runs
		var ret = new ArrayList<Boolean>
		ret.add(gt)
		ret.add(im)
		ret.add(ni)
		ret.add(nr)
		return ret
	}
	
	def static boolean isMultiplication (MeasurementRequirementElicitation m, ExperimentSpace es, List<String> exp, List<String> expVariable){
		var act =    isMultiplication(encoodeDouble(m,es,exp).subList(2,6),encoodeDouble(m,es,expVariable).subList(2,6))   // actor (pos. 2 till 5)
		var req =    isMultiplication(encoodeDouble(m,es,exp).subList(6,8),encoodeDouble(m,es,expVariable).subList(6,8))   // requirement select (pos. 6 and 7)
		var own =    isMultiplication(encoodeDouble(m,es,exp).subList(8,10),encoodeDouble(m,es,expVariable).subList(8,10)) // owner select (post 8 and 9)

		var actSim = isMultiplicationSim(encoodeDouble(m,es,exp).subList(2,6),encoodeDouble(m,es,expVariable).subList(2,6))   // actor (pos. 2 till 5)
		var reqSim = isMultiplicationSim(encoodeDouble(m,es,exp).subList(6,8),encoodeDouble(m,es,expVariable).subList(6,8))   // requirement select (pos. 6 and 7)
		var ownSim = isMultiplicationSim(encoodeDouble(m,es,exp).subList(8,10),encoodeDouble(m,es,expVariable).subList(8,10)) // owner select (post 8 and 9)
		
		return (act && reqSim && ownSim) || ( actSim && req && ownSim ) || ( actSim && reqSim && own )
	}
	
	// checks whether the first list of doubles is a multiple of the second list of doubles 
	def static boolean isMultiplication (List<Double> exp, List<Double> expVariable){
		if(exp.size!=expVariable.size || exp.size==0 || expVariable.size==0 )
		// in principle, size cannot be zero by excluding zero parameter experiments
			throw new Throwable("isMultiplication: input parameters are not the same size or size zero.")
		var List<Double> div = new ArrayList<Double>
		for(cnt:0..exp.size-1) // store the quotients in an array
			if(exp.get(cnt)>1 && expVariable.get(cnt)==0) // infinity means no multiplication
				return false 
			else if (!(exp.get(cnt)==0 && expVariable.get(cnt)==0)) // not both zero (both zero -> add nothing)
				div.add(exp.get(cnt)/expVariable.get(cnt))
		for(cnt:0..div.size-1) // compare the quotients to the first quotient in the list
			if(Math.abs(div.get(cnt)-div.get(0))>0.01) // found a counter proof
				return false
		return true
	}

	// checks whether the first list of doubles is a multiple or equal to the second list of doubles	
	def static boolean isMultiplicationSim (List<Double> exp, List<Double> expVariable){
		if(exp.size!=expVariable.size || exp.size==0 || expVariable.size==0 )
		// in principle, size cannot be zero by excluding zero parameter experiments
			throw new Throwable("isMultiplicationSim: input parameters are not the same size or size zero.")
		if(isMultiplication(exp,expVariable))
			return true
		for(cnt:0..exp.size-1)
			if(exp.get(cnt)!=expVariable.get(cnt))
				return false
		return true
	} 
	

		var r2copy=CreateLangConstructs.clone(r2)
		
		var trace=AgriDSLFactoryImpl::init.createRequirementTrace
		trace.req1.add(r1copy)
		trace.req2.add(r2copy)
		trace.timestamp = time
		m.requirementTraces.add(trace)
	}
	
	// add a trace with a given time and without a r1
	def static addtrace (Model m, Requirement r2, int time){
		var r2copy=CreateLangConstructs.clone(r2)
		
		var trace=AgriDSLFactoryImpl::init.createRequirementTrace
		trace.req2.add(r2copy)
		trace.timestamp = time
		m.requirementTraces.add(trace)
	}	
	
	def static String returnActorBehavior (int n){
		if(n==1) 	  return "coerce"
		else if(n==2) return "intersection"
		else if(n==3) return "conjunection"
		else if(n==4) return "compromise"
	}
	
	def static String returnSimilarityMeasure (int n){
		if(n==1) 	  return "jaccard"
		else if(n==2) return "entropy"		
	}
	
	



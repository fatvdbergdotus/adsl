	// stores an experiment as a list of doubles (rounded integers), namely the parameters of the DSL	
	def static List<Double> encoodeDouble (MeasurementRequirementElicitation m, ExperimentSpace es, List<String> exp1){
		var ret = new ArrayList<Double>
		for(v:encode(m,es,exp1))
			ret.add(new Double(v))
		return ret
	}
	
	def static boolean greaterThanEncode (List<Integer> exp1, List<Integer> exp2){
		if(exp1.size!=exp2.size)
			throw new Throwable("greaterThan: input parameters are not the same size")
		else if (exp1.empty)
			return false // they equal each other
		else if (exp1.head>exp2.head)
			return true
		else if (exp1.head==exp2.head)
			return greaterThanEncode(exp1.tail.toList,exp2.tail.toList)
		else // (exp1.head<exp2.head)
			return false
	}

	// checks whether actor behavior, requirement selection or owner selection parameters 
	def static boolean zerosInTheExpermimentParameters(MeasurementRequirementElicitation m, ExperimentSpace es, List<String> expelem){
		if(ResolveAExp.resolveAExp(m.is,es,expelem)==0 && ResolveAExp.resolveAExp(m.cj,es,expelem)==0 
		   && ResolveAExp.resolveAExp(m.cp,es,expelem)==0 && ResolveAExp.resolveAExp(m.co,es,expelem)==0)
			return true
		if(ResolveAExp.resolveAExp(m.en,es,expelem)==0 && ResolveAExp.resolveAExp(m.ja,es,expelem)==0)
			return true
		if(ResolveAExp.resolveAExp(m.enOwner,es,expelem)==0 && ResolveAExp.resolveAExp(m.jaOwner,es,expelem)==0)
			return true
		return false // the experiment is good to go
	}
	

		var validationScore = compareSetOfRequirements(resource,fsa,model.requirements,RequirementOperationsOnDSL.returnRequirementsWithHighestTimestamp(model))
		fsa.generateFile(fsapath+"validate.txt",validationScore.toString)
		return validationScore -> params
	}
	
	def static addTracesAndUpdateRequirements(Model model, Requirement r1, Requirement r2, int r1number, int r2number, Requirement r){
		addtrace(model,r1,r)
		addtrace(model,r2,r)
		RequirementOperationsOnDSL.copyRequirementsNextTimeStepAndRemoveTwoAndAddOne(model,r1number,r2number,r)		
	}
	
	def static double compareSetOfRequirements(Resource res, IFileSystemAccess2 fsa, List<Requirement> r1, List<Requirement> r2){
		var List<Pair<String,String>> DSIreq1 = AgriDSLGenerator.retrieveDSIreq(res,fsa,r1) 
		var List<Pair<String,String>> DSIreq2 = AgriDSLGenerator.retrieveDSIreq(res,fsa,r2)
		var List<String> designs			  = listOfUniqueDesigns(DSIreq1)
		var double sum						  = 0
		
		for(String design:designs){
			var double fractionDesMeetReq1 = fractionDesignMeetsRequirements(DSIreq1, design)
			var double fractionDesMeetReq2 = fractionDesignMeetsRequirements(DSIreq2, design)
			sum=sum+Math.pow(fractionDesMeetReq1-fractionDesMeetReq2,2)
		}
		
		var finalScore=Math.sqrt(sum)
		return finalScore
	}
	
	// determines the fraction of requirements a design meets
	def static double fractionDesignMeetsRequirements (List<Pair<String,String>> ListDesignBooleans, String design){ // e.g., [(a,b,c) -> 00010101, (a,b,c) -> 00010101, (a,b,c) -> 00010101, ....  
		for(designBooleans:ListDesignBooleans){
			if(design.equals(designBooleans.key)){
				var fobt = fractionOfBooleansTrue(designBooleans.value)
				return fobt
			}
		}
		throw new Throwable("fractionDesignMeetsRequirements: design "+design+" not found in ListDesignBooleans.")
	}
	
	def static double fractionOfBooleansTrue (String booleans){ // booleans represented as follows: 00110101101
		var double cntTrue=0.0
		for(cnt:0..booleans.length-1){
			//System.out.println(booleans.charAt(cnt).toString.equals("1"))
			if(booleans.charAt(cnt).toString.equals("1")) // true
				cntTrue=cntTrue+1.0
		}		
		//System.out.println(cntTrue + " / "+ booleans.length)
		return cntTrue / ( 1.0 * booleans.length )
	}

	// returns the unique set of DSIs given a DSIreq table
	def static List<String> listOfUniqueDesigns (List<Pair<String,String>> DSIreq){
		var Set<String> DSI = new HashSet<String>
		for(d:DSIreq)
			DSI.add(d.key)
		return DSI.toList
	}
	

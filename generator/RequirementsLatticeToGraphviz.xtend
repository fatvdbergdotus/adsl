	// create entries, e.g., for length=3: [f,f,f] [f,f,t] [f,t,f] [t,f,f], ...
	def static List<List<Boolean>> createLatticeEntries (int length){
		var List<List<Boolean>> entries = new ArrayList

		// run through the 2^length options
		for(cnt:0..pow(2,length)-1)
			entries.add(latticeEntry(cnt,length))
		return entries
	}
	
	def static List<Boolean> latticeEntry (int count, int length){
		var List<Boolean> ret = new ArrayList
		var x = count
		
		// compute the binary digits, one at a time
		for(cnt:0..length-1){
			if(x/2*2==x)
				ret.add(true)
			else
				ret.add(false)
			x=x/2
		}
		return ret
	}

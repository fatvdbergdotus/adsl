	def static boolean pointsTo(List<Boolean> l1, List<Boolean> l2, int length){
		var int delta=0
		if(length==0)
			return false
		
		for(cnt:0..length-1){
			if(l1.get(cnt)&&!l2.get(cnt)) // l1 has a higher value than l2 for this dimension
				return false
			if(!l1.get(cnt)&&l2.get(cnt))
				delta=delta+1
		}
		return (delta==1)	
	}
	
